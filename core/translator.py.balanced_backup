        'und': 'en',  # Fallback su inglese
    }

    # Parametri ottimizzati per Aya (modello piÃ‚Â¹ grande, parametri piÃ‚Â¹ conservativi)
    NUM_BEAMS = 5  # Ridotto per velocitÃ‚Â 
    NO_REPEAT_NGRAM_SIZE = 3
    MAX_LENGTH_SENTENCE = 256
    
    # Batch Size Adattivo (piÃ‚Â¹ piccolo di NLLB per modello 8B)
    BATCH_SIZE_ADAPTIVE = 4  # RTX 3060 12GB con FP16
    MIN_BATCH_SIZE = 1
    MAX_BATCH_SIZE = 8

    def __init__(self, log_callback: Optional[Callable] = None):
        """Inizializza il traduttore Aya usando l'istanza singleton"""
        super().__init__(log_callback)
        self.model, self.tokenizer, self.device = _get_aya_translator_resources()
        self.current_batch_size = self.BATCH_SIZE_ADAPTIVE
        self.oom_consecutive_failures = 0

    def _aya_to_iso(self, lang_code: str) -> Optional[str]:
        """Converte codice ISO 639-2/1 in codice Aya (ISO 639-1)"""
        result = self.LANGUAGE_CODES.get(lang_code.lower(), None)
        if result is None:
            logger.warning(f"Codice lingua '{lang_code}' non trovato in LANGUAGE_CODES Aya")
        return result

    def _create_prompt(self, text: str, src_lang: str, tgt_lang: str) -> str:
        """
        Crea prompt per Aya-23-8B
        
        Aya funziona meglio con istruzioni esplicite in linguaggio naturale
        
        Args:
            text: Testo da tradurre
            src_lang: Codice lingua sorgente (ISO 639-1)
            tgt_lang: Codice lingua target (ISO 639-1)
            
        Returns:
            Prompt formattato per Aya
        """
        # Mappa codici in nomi lingua per prompt piÃ‚Â¹ naturale
        lang_names = {
            'en': 'English', 'it': 'Italian', 'fr': 'French', 'de': 'German',
            'es': 'Spanish', 'pt': 'Portuguese', 'ru': 'Russian', 'ja': 'Japanese',
            'zh': 'Chinese', 'ar': 'Arabic', 'ko': 'Korean', 'hi': 'Hindi',
            'pl': 'Polish', 'tr': 'Turkish', 'nl': 'Dutch', 'cs': 'Czech',
            'uk': 'Ukrainian', 'he': 'Hebrew', 'vi': 'Vietnamese', 'th': 'Thai',
            'el': 'Greek', 'id': 'Indonesian', 'fa': 'Persian'
        }
        
        src_name = lang_names.get(src_lang, src_lang)
        tgt_name = lang_names.get(tgt_lang, tgt_lang)
        
        # Prompt ottimizzato per traduzione sottotitoli
        prompt = f"Translate the following {src_name} subtitle text to {tgt_name}. Preserve formatting and maintain natural, idiomatic language:\n\n{text}"
        
        return prompt

    def _run_translation(self, texts: List[str], src_lang: str, tgt_lang: str) -> List[str]:
        """
        Esegue traduzione batch con gestione OOM dinamica per Aya
        
        Args:
            texts: Lista testi da tradurre
            src_lang: Lingua sorgente (codice ISO 639-1)
            tgt_lang: Lingua target (codice ISO 639-1)
            
        Returns:
            Lista testi tradotti
            
        Raises:
            Exception: Se errore critico (OOM non recuperabile o altro)
        """
        try:
            # Crea prompts per Aya
            prompts = [self._create_prompt(text, src_lang, tgt_lang) for text in texts]
            
            # Tokenizzazione
            inputs = self.tokenizer(
                prompts,
                return_tensors="pt",
                padding=True,
                truncation=True,
                max_length=self.MAX_LENGTH_SENTENCE
            ).to(self.device)
            
            # Genera traduzione (CausalLM)
            with torch.no_grad():
                outputs = self.model.generate(
                    **inputs,
                    max_new_tokens=self.MAX_LENGTH_SENTENCE,  # ✅ max_new_tokens per decoder-only
                    num_beams=self.NUM_BEAMS,
                    no_repeat_ngram_size=self.NO_REPEAT_NGRAM_SIZE,
                    temperature=0.7,
                    do_sample=False,
                    pad_token_id=self.tokenizer.pad_token_id,
                    eos_token_id=self.tokenizer.eos_token_id
                )
            
            # Decodifica
            translations = self.tokenizer.batch_decode(outputs, skip_special_tokens=True)
            
            # ✅ Rimuovi prompt dall'output (decoder-only include prompt nella generazione)
            cleaned_translations = []
            for i, translation in enumerate(translations):
                # Rimuovi il prompt originale dall'output
                original_prompt = prompts[i]
                if translation.startswith(original_prompt):
                    # Rimuovi esattamente il prompt
                    translation = translation[len(original_prompt):].strip()
                else:
                    # Fallback: cerca pattern comune
                    if ':' in translation:
                        parts = translation.split(':', 1)
                        if len(parts) > 1:
                            translation = parts[1].strip()
                
                cleaned_translations.append(translation)
            
            # Reset counter su successo
            self.oom_consecutive_failures = 0
            
            return cleaned_translations
            
        except RuntimeError as e:
            if "out of memory" in str(e).lower() or "CUDA" in str(e):
                self.oom_consecutive_failures += 1
                
                # Svuota cache
                if self.use_gpu:
                    torch.cuda.empty_cache()
                    torch.cuda.synchronize()
                
                # Riduzione batch size
                if self.current_batch_size > self.MIN_BATCH_SIZE:
                    new_batch_size = max(self.MIN_BATCH_SIZE, self.current_batch_size // 2)
                    self.log(f"   Ã…Â¡Ã‚Â Ã‚Â¸Ã‚Â OOM! Riduco batch: {self.current_batch_size} Â â„¢ {new_batch_size}")
                    self.current_batch_size = new_batch_size
                    raise Exception("Out of Memory - Batch Size Ridotto")
                else:
                    self.log(f"   Ã‚ÂÃ…â€™ OOM critico con batch_size=1. Memoria GPU insufficiente.")
                    raise Exception("Out of Memory - GPU Memoria Insufficiente")
            else:
                raise

    def translate_file(self, input_path: Path, output_path: Path, 
                      src_lang: str, tgt_lang: str) -> bool:
        """
        Traduce file SRT da lingua sorgente a lingua target usando Aya-23-8B
        
        Args:
            input_path: Path del file SRT da tradurre
            output_path: Path del file SRT tradotto
            src_lang: Codice lingua sorgente (ISO 639-2, es: 'eng')
            tgt_lang: Codice lingua target (ISO 639-2, es: 'ita')
            
        Returns:
            True se successo, False altrimenti
        """
        try:
            self.log(f"\nÃ…Â¸Ã…â€™Ã‚Â Traduzione Aya-23-8B: {src_lang} Â â„¢ {tgt_lang}")
            
            # Conversione codici lingua
            src_aya = self._aya_to_iso(src_lang)
            tgt_aya = self._aya_to_iso(tgt_lang)
            
            if not src_aya or not tgt_aya:
                self.log(f"Ã‚ÂÃ…â€™ Codice lingua non supportato da Aya: {src_lang} o {tgt_lang}")
                return False
            
            # Parsing SRT
            parsed_subtitles = self._parse_srt(input_path)
            total = len(parsed_subtitles)
            translated_subtitles = []
            
            if total == 0:
                self.log("  Ã…Â¡Ã‚Â Ã‚Â¸Ã‚Â File SRT vuoto o parsing fallito")
                with open(output_path, 'w', encoding='utf-8') as f:
                    f.write("")
                return True
            
            self.log(f"  Trovati {total} sottotitoli da tradurre")
            self.log(f"  ModalitÃ‚Â : FP16 ottimizzata per RTX 3060")
            
            # Reset parametri
            self.current_batch_size = self.BATCH_SIZE_ADAPTIVE
            self.oom_consecutive_failures = 0
            
            # Ciclo di traduzione
            i = 0
            max_retries_per_batch = 3
            
            while i < total:
                batch_index = (i // self.current_batch_size) + 1
                total_batches = (total + self.current_batch_size - 1) // self.current_batch_size
                
                batch = parsed_subtitles[i:i + self.current_batch_size]
                texts = [item[3] for item in batch]
                
                self.log(f"  Batch {batch_index}/{total_batches} ({i+1}-{min(i + self.current_batch_size, total)}) [size={len(batch)}]")
                
                retries = 0
                batch_success = False
                
                while retries < max_retries_per_batch and not batch_success:
                    try:
                        results = self._run_translation(texts, src_aya, tgt_aya)
                        
                        for j, (index, start, end, _) in enumerate(batch):
                            translated_subtitles.append((index, start, end, results[j]))
                        
                        batch_success = True
                        i += len(batch)
                    
                    except Exception as e:
                        retries += 1
                        
                        if 'Out of Memory - Batch Size Ridotto' in str(e):
                            self.log(f"   Retry #{retries}/{max_retries_per_batch} con batch size ridotto...")
                            batch = parsed_subtitles[i:i + self.current_batch_size]
                            texts = [item[3] for item in batch]
                            
                        elif 'Out of Memory - GPU Memoria Insufficiente' in str(e):
                            self.log(f"Ã‚ÂÃ…â€™ ERRORE CRITICO: GPU memoria insufficiente")
                            self.log(f"   Mantengo sottotitoli originali per batch corrente e procedo")
                            for item in batch:
                                translated_subtitles.append(item)
                            i += len(batch)
                            break
                            
                        else:
                            self.log(f"Ã‚ÂÃ…â€™ Errore nel batch: {str(e)[:100]}")
                            self.log(f"   Mantengo testi originali per questo batch")
                            for item in batch:
                                translated_subtitles.append(item)
                            i += len(batch)
                            break
                
                if not batch_success and retries >= max_retries_per_batch:
                    self.log(f"Ã…Â¡Ã‚Â¡Ã‚Â¸Ã‚Â Batch fallito dopo {max_retries_per_batch} tentativi. Mantengo originali.")
                    for item in batch:
                        translated_subtitles.append(item)
                    i += len(batch)
                        
            # Salvataggio
            srt_content = self._generate_srt(translated_subtitles)
            with open(output_path, 'w', encoding='utf-8') as f:
                f.write(srt_content)
            
            self.log(f"\nÃ…â€œÂ¦ Traduzione Aya completata: {output_path.name}")
            self.log(f"   Sottotitoli tradotti: {len(translated_subtitles)}/{total}")
            return True
            
        except Exception as e:
            error_msg = f"Ã‚ÂÃ…â€™ Errore traduzione file Aya: {e}"
            self.log(error_msg)
            logger.error(error_msg, exc_info=True)
            return False
    
    def cleanup(self):
        """Pulizia risorse e memoria GPU (Non scarica il modello Singleton)"""
        try:
            if self.use_gpu:
                torch.cuda.empty_cache()
                torch.cuda.synchronize()
            logger.info("-> Cache GPU svuotata post-traduzione Aya")
        except Exception as e:
            logger.error(f"-> Errore durante cleanup GPU: {e}")


