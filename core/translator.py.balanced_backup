def get_translator(log_callback: Optional[Callable] = None) -> BaseTranslator:
    """
    Factory function intelligente per creare istanze di traduttori
    
    Seleziona automaticamente il modello basandosi sulla configurazione utente.
    Usa pattern singleton condiviso per efficienza memoria.
    
    Args:
