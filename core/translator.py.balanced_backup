def unload_all_translation_models():
    """
    Scarica TUTTI i modelli di traduzione dalla memoria
    
    Usare solo alla fine dell'applicazione per liberare completamente VRAM.
    """
    global _nllb_model, _nllb_tokenizer, _aya_model, _aya_tokenizer
    
    success = True
    
    # Unload NLLB
    try:
        with _nllb_lock:
            if _nllb_model:
                del _nllb_model
                del _nllb_tokenizer
                _nllb_model = None
                _nllb_tokenizer = None
                logger.info("-> Modello NLLB scaricato dalla memoria")
    except Exception as e:
        logger.error(f"Ã‚ÂÃ…â€™ Errore scaricamento NLLB: {e}")
        success = False
    
    # Unload Aya
    try:
        with _aya_lock:
            if _aya_model:
                del _aya_model
                del _aya_tokenizer
                _aya_model = None
                _aya_tokenizer = None
                logger.info("-> Modello Aya scaricato dalla memoria")
    except Exception as e:
        logger.error(f"Ã‚ÂÃ…â€™ Errore scaricamento Aya: {e}")
        success = False
    
    # Cleanup finale GPU
    if torch.cuda.is_available():
        torch.cuda.empty_cache()
        torch.cuda.synchronize()
        logger.info("-> Cache CUDA finale svuotata")
    
    return success


